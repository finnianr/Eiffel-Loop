<?xml version = "1.0" encoding = "ISO-8859-1"?>
<system xmlns = "http://www.eiffel.com/developers/xml/configuration-1-4-0" xmlns:xsi = "http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation = "http://www.eiffel.com/developers/xml/configuration-1-4-0 http://www.eiffel.com/developers/xml/configuration-1-4-0.xsd" name = "eiffel_loop_eros_server" uuid = "E2778A70-6570-11F1-87F8-3F602C69933A" library_target = "NEL_fft_math">
	<target name = "NEL_fft_math">
		<description>Numeric Eiffel Library for fast fourier transformas</description>
		<root all_classes = "true"/>
		<library name = "base" location = "$ISE_EIFFEL/library/base/base.ecf"/>
		<cluster name = "nel_math" location = "NEL-math" recursive = "true"/>
	</target>
</system>
